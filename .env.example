# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is listed in .gitignore.
# In production, set these in your hosting platform's environment variable dashboard (e.g. Vercel).

# ── Solana RPC — Helius (https://helius.dev) ──────────────────────────────────
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ── EVM block explorers (kept for reference; scanner currently uses Blockscout which needs no key) ──
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ── AI — Anthropic (required for TJ chat — https://console.anthropic.com) ─────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to "production" in your hosting platform. Controls error verbosity.
# NODE_ENV is set automatically by Next.js build — do not set it manually in .env.local.
